<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/presetListFragment">

    <fragment
        android:id="@+id/presetListFragment"
        android:name="com.androidapp.pomodorotimer.ui.list.PresetListFragment"
        android:label="@string/screen_preset_list">
        <action android:id="@+id/action_list_to_presetEdit" app:destination="@id/presetEditFragment" />
        <action android:id="@+id/action_list_to_timerRun"   app:destination="@id/timerRunFragment" />
    </fragment>

    <fragment
        android:id="@+id/presetEditFragment"
        android:name="com.androidapp.pomodorotimer.ui.presetedit.PresetEditFragment"
        android:label="@string/screen_preset_edit">
        <argument android:name="presetId" app:argType="integer" android:defaultValue="-1" />
        <action android:id="@+id/action_presetEdit_to_routineEdit" app:destination="@id/routineEditFragment" />
    </fragment>

    <fragment
        android:id="@+id/routineEditFragment"
        android:name="com.androidapp.pomodorotimer.ui.routineedit.RoutineEditFragment"
        android:label="@string/screen_routine_edit">
        <argument android:name="presetId" app:argType="integer" />
    </fragment>

    <fragment
        android:id="@+id/timerRunFragment"
        android:name="com.androidapp.pomodorotimer.ui.timerrun.TimerRunFragment"
        android:label="@string/screen_timer_run">
        <argument android:name="presetId" app:argType="integer" />
    </fragment>

</navigation>